# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Vite / runtime
.vite/
.vercel/

# Local env overrides (NOT the committed .env which holds the public
# Supabase URL + anon key — safe to commit, see:
# https://supabase.com/docs/guides/api/api-keys)
.env.local
.env.*.local

# Editor
.DS_Store
.idea/
.vscode/

# Mobile app (Expo) build artifacts — the source in mobile/** is
# committed, but generated dirs are not. mobile/node_modules is
# already covered by the top-level `node_modules/` rule.
mobile/.expo/
mobile/ios/
mobile/android/
mobile/web-build/
mobile/dist/
mobile/expo-env.d.ts

# Generated vite config artifacts
vite.config.d.ts
vite.config.js
.env
